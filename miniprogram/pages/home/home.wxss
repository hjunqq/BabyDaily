.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFF7F9 100%);
}

/* State */
.state-box {
  text-align: center;
  padding: 120rpx 0;
  color: #8b7670;
  font-size: 28rpx;
}
.retry-btn {
  margin-top: 20rpx;
  background: #F3B6C2;
  color: #fff;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0 24rpx;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #F7EFEB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.header-info {
  display: flex;
  flex-direction: column;
}
.header-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A342E;
  line-height: 1.2;
}
.header-date {
  font-size: 24rpx;
  color: #8b7670;
  margin-top: 4rpx;
}

/* Last Feed Card */
.feed-card {
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}
.feed-label {
  font-size: 24rpx;
  color: #8b7670;
}
.feed-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin: 8rpx 0;
}
.feed-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: #4A342E;
}
.feed-tag {
  font-size: 22rpx;
  background: rgba(243,182,194,0.5);
  color: #4A342E;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}
.feed-elapsed {
  font-size: 30rpx;
  font-weight: 600;
  color: #e57373;
  display: block;
}
.feed-detail {
  font-size: 24rpx;
  color: #8b7670;
  margin-top: 8rpx;
  display: block;
}

/* Countdown Section */
.countdown-section {
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
  margin-bottom: 16rpx;
  display: block;
}
.countdown-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}
.bar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
}
.bar-value {
  font-size: 26rpx;
  color: #4A342E;
  font-weight: 500;
}

/* Stats Section */
.stats-section {
  margin-bottom: 24rpx;
}
.stat-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.stat-icon {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
.milk-stat .stat-icon { background: #FFE8EC; }
.supplement-stat .stat-icon { background: #E8F5E9; }
.stat-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.stat-title {
  font-size: 24rpx;
  color: #8b7670;
}
.stat-value-row {
  display: flex;
  align-items: baseline;
  margin-top: 4rpx;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A342E;
}
.stat-unit {
  font-size: 24rpx;
  color: #8b7670;
}
.stat-count {
  font-size: 24rpx;
  color: #8b7670;
  margin-left: 8rpx;
}
.pill {
  font-size: 30rpx;
  font-weight: 600;
}
.pill.taken { color: #4CAF50; }
.pill.not-taken { color: #ccc; }
.pill-sep {
  margin: 0 12rpx;
  color: #e0e0e0;
}

/* Feed Detail */
.feed-detail-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.feed-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.feed-detail-summary {
  font-size: 24rpx;
  color: #e57373;
  font-weight: 500;
}
.feed-detail-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.feed-detail-item {
  background: #FFF5F5;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  gap: 8rpx;
}
.feed-detail-time {
  font-size: 24rpx;
  color: #8b7670;
}
.feed-detail-value {
  font-size: 24rpx;
  color: #e57373;
  font-weight: 600;
}

/* Action Buttons */
.actions-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.action-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid transparent;
}
.action-btn.feed-action { border-left-color: #F3B6C2; }
.action-btn.diaper-action { border-left-color: #64b5f6; }
.action-btn.bath-action { border-left-color: #81c784; }
.action-btn.ad-action { border-left-color: #CE93D8; }
.action-btn.d3-action { border-left-color: #FFD54F; }
.action-btn.sleep-action { border-left-color: #B39DDB; }
.action-btn.done { opacity: 0.5; }
.action-icon {
  font-size: 36rpx;
}
.action-info {
  display: flex;
  flex-direction: column;
}
.action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
}
.action-sub {
  font-size: 20rpx;
  color: #8b7670;
  margin-top: 2rpx;
}

/* Records */
.records-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 40rpx;
}
.records-header {
  margin-bottom: 16rpx;
}
.record-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}
.record-item:last-child {
  border-bottom: none;
}
.record-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}
.record-icon-wrap.feed { background: #FFE8EC; }
.record-icon-wrap.diaper { background: #E3F2FD; }
.record-icon-wrap.sleep { background: #F3E5F5; }
.record-icon-wrap.bath { background: #E0F7FA; }
.record-icon-wrap.supplement { background: #E8F5E9; }
.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.record-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #4A342E;
}
.record-time {
  font-size: 22rpx;
  color: #8b7670;
}
.record-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
  margin-right: 8rpx;
}
.record-arrow {
  font-size: 36rpx;
  color: #ccc;
}
.empty-text {
  text-align: center;
  padding: 40rpx;
  color: #8b7670;
  font-size: 26rpx;
}
