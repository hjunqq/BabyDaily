.container {
  min-height: 100vh;
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFF7F9 100%);
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #4A342E;
}

.subtitle {
  font-size: 26rpx;
  color: #8b7670;
  margin-top: 6rpx;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFE4E9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

/* Loading & Error */
.loading-box, .error-box {
  text-align: center;
  padding: 80rpx 0;
  color: #8b7670;
  font-size: 28rpx;
}

.retry-btn {
  margin-top: 20rpx;
  background: #F3B6C2;
  color: #fff;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
  margin-bottom: 16rpx;
}

/* Timers */
.timers-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.timer-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #e5e5e5;
}

.timer-card.feed-timer { border-left-color: #F3B6C2; }
.timer-card.pee-timer { border-left-color: #64b5f6; }
.timer-card.poo-timer { border-left-color: #ffb74d; }
.timer-card.bath-timer { border-left-color: #81c784; }

.timer-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.timer-label {
  font-size: 22rpx;
  color: #8b7670;
}

.timer-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A342E;
  margin-top: 4rpx;
}

/* Stats */
.stats-section {
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A342E;
}

.stat-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #8b7670;
}

.stat-label {
  font-size: 22rpx;
  color: #8b7670;
  margin-top: 4rpx;
}

/* Supplement Pills */
.supplement-pills {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 8rpx;
  margin-top: 4rpx;
}

.pill {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.pill.taken {
  background: #E8F5E9;
  color: #2E7D32;
}

.pill.not-taken {
  background: #F5F5F5;
  color: #BDBDBD;
}

/* Quick Actions */
.actions-section {
  margin-bottom: 20rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.action-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
}

.action-btn.feed-action { border-color: #F3B6C2; }
.action-btn.diaper-action { border-color: #64b5f6; }
.action-btn.sleep-action { border-color: #B39DDB; }
.action-btn.supplement-action { border-color: #66bb6a; }
.action-btn.bath-action { border-color: #81c784; }
.action-btn.more-action { border-color: #e0e0e0; }

.action-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.action-icon-wrap {
  margin-bottom: 6rpx;
}

.action-icon-wrap.done {
  opacity: 0.5;
}

.action-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #4A342E;
}

/* Activity List */
.list-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-icon {
  font-size: 32rpx;
  width: 56rpx;
}

.activity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
}

.activity-time {
  font-size: 22rpx;
  color: #8b7670;
}

.activity-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A342E;
}

.empty-text {
  text-align: center;
  padding: 40rpx;
  color: #8b7670;
  font-size: 26rpx;
}
