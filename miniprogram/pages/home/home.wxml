<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="header-left">
      <text class="title">{{greeting}}</text>
      <text class="subtitle" wx:if="{{babyName}}">{{babyName}} · {{babyAge}}</text>
    </view>
    <view class="header-avatar">🌸</view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="error-box">
    <text>{{error}}</text>
    <button class="retry-btn" size="mini" bindtap="loadData">重试</button>
  </view>

  <block wx:else>
    <!-- Timers -->
    <view class="timers-section">
      <view class="timer-card feed-timer">
        <text class="timer-icon">🍼</text>
        <text class="timer-label">上次喂奶</text>
        <text class="timer-value">{{lastFeedText}}</text>
      </view>
      <view class="timer-card pee-timer">
        <text class="timer-icon">💧</text>
        <text class="timer-label">上次尿尿</text>
        <text class="timer-value">{{lastPeeText}}</text>
      </view>
      <view class="timer-card poo-timer">
        <text class="timer-icon">💩</text>
        <text class="timer-label">上次便便</text>
        <text class="timer-value">{{lastPooText}}</text>
      </view>
      <view class="timer-card bath-timer">
        <text class="timer-icon">🛁</text>
        <text class="timer-label">上次洗澡</text>
        <text class="timer-value">{{lastBathText}}</text>
      </view>
    </view>

    <!-- Today Stats -->
    <view class="stats-section">
      <view class="section-title">今日概览</view>
      <view class="stats-row">
        <view class="stat-card">
          <text class="stat-icon">🍼</text>
          <text class="stat-value">{{summary.milkMl}}<text class="stat-unit">ml</text></text>
          <text class="stat-label">奶量 · {{summary.feedCount}}次</text>
        </view>
        <view class="stat-card">
          <text class="stat-icon">🧷</text>
          <text class="stat-value">{{summary.diaperWet + summary.diaperSoiled}}<text class="stat-unit">次</text></text>
          <text class="stat-label">尿布</text>
        </view>
        <view class="stat-card">
          <view class="supplement-pills">
            <view class="pill {{summary.todayAdTaken ? 'taken' : 'not-taken'}}">
              <text>AD {{summary.todayAdTaken ? '✓' : '○'}}</text>
            </view>
            <view class="pill {{summary.todayD3Taken ? 'taken' : 'not-taken'}}">
              <text>D3 {{summary.todayD3Taken ? '✓' : '○'}}</text>
            </view>
          </view>
          <text class="stat-label">营养补充</text>
        </view>
      </view>
    </view>

    <!-- Quick Actions -->
    <view class="actions-section">
      <view class="section-title">快捷操作</view>
      <view class="actions-grid">
        <view class="action-btn feed-action" bindtap="quickFeed">
          <text class="action-icon">🍼</text>
          <text class="action-text">喂奶</text>
        </view>
        <view class="action-btn diaper-action" bindtap="quickDiaper" data-type="PEE">
          <text class="action-icon">💧</text>
          <text class="action-text">尿尿</text>
        </view>
        <view class="action-btn diaper-action" bindtap="quickDiaper" data-type="POO">
          <text class="action-icon">💩</text>
          <text class="action-text">便便</text>
        </view>
        <view class="action-btn sleep-action" bindtap="quickSleep">
          <text class="action-icon">💤</text>
          <text class="action-text">睡眠</text>
        </view>
        <view class="action-btn supplement-action" bindtap="quickSupplement" data-type="VITA_AD">
          <view class="action-icon-wrap {{summary.todayAdTaken ? 'done' : ''}}">
            <text class="action-icon">💊</text>
          </view>
          <text class="action-text">AD{{summary.todayAdTaken ? ' ✓' : ''}}</text>
        </view>
        <view class="action-btn supplement-action" bindtap="quickSupplement" data-type="VITA_D3">
          <view class="action-icon-wrap {{summary.todayD3Taken ? 'done' : ''}}">
            <text class="action-icon">☀️</text>
          </view>
          <text class="action-text">D3{{summary.todayD3Taken ? ' ✓' : ''}}</text>
        </view>
        <view class="action-btn bath-action" bindtap="goToRecord">
          <text class="action-icon">🛁</text>
          <text class="action-text">洗澡</text>
        </view>
        <view class="action-btn more-action" bindtap="goToRecord">
          <text class="action-icon">📝</text>
          <text class="action-text">更多</text>
        </view>
      </view>
    </view>

    <!-- Recent Records -->
    <view class="list-section">
      <view class="section-header">
        <text class="section-title">最近记录</text>
      </view>
      <view class="activity-list" wx:if="{{recentRecords.length > 0}}">
        <block wx:for="{{recentRecords}}" wx:key="id">
          <view class="activity-item">
            <text class="activity-icon">{{item.icon}}</text>
            <view class="activity-info">
              <text class="activity-type">{{item.type}}</text>
              <text class="activity-time">{{item.time}}</text>
            </view>
            <text class="activity-value">{{item.value}}</text>
          </view>
        </block>
      </view>
      <view wx:else class="empty-text">
        <text>暂无记录，点击上方按钮开始记录</text>
      </view>
    </view>
  </block>
</view>
