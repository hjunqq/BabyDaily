<view class="page">
    <view class="hero">
        <view class="hero-badge">BabyDaily</view>
        <view class="title">欢迎回来</view>
        <view class="subtitle">已绑定过家庭的微信，一键登录即可恢复记录。</view>
    </view>

    <view class="card">
        <button
            class="submit wechat-submit"
            loading="{{loading}}"
            disabled="{{loading}}"
            bindtap="submitWechatLogin"
        >
            {{loading ? '登录中...' : '微信一键登录'}}
        </button>

        <view class="divider"><text>或</text></view>

        <view class="mode-switch">
            <view
                class="mode-chip {{mode === 'invite' ? 'active' : ''}}"
                data-mode="invite"
                bindtap="switchMode"
            >
                邀请码加入
            </view>
            <view
                class="mode-chip {{mode === 'admin' ? 'active' : ''}}"
                data-mode="admin"
                bindtap="switchMode"
            >
                测试账号登录
            </view>
        </view>

        <block wx:if="{{mode === 'invite'}}">
            <view class="section-title">申请加入家庭</view>
            <view class="section-desc">输入 8 位邀请码后，会自动创建微信会话并提交加入申请。</view>
            <input
                class="input invite-input"
                placeholder="请输入邀请码"
                maxlength="8"
                value="{{inviteCode}}"
                bindinput="onInviteInput"
            />
            <button
                class="submit"
                loading="{{loading}}"
                disabled="{{loading}}"
                bindtap="submitInviteLogin"
            >
                {{loading ? '提交中...' : '用邀请码进入'}}
            </button>
        </block>

        <block wx:elif="{{mode === 'admin'}}">
            <view class="section-title">管理员审核入口</view>
            <view class="section-desc">使用测试用户名和密码登录后，可进入家庭管理页审核申请。</view>
            <input
                class="input"
                placeholder="testadmin"
                value="{{username}}"
                bindinput="onUsernameInput"
            />
            <input
                class="input"
                placeholder="password"
                password="true"
                value="{{password}}"
                bindinput="onPasswordInput"
            />
            <button
                class="submit admin-submit"
                loading="{{loading}}"
                disabled="{{loading}}"
                bindtap="submitAdminLogin"
            >
                {{loading ? '登录中...' : '进入审核'}}
            </button>
        </block>

        <view wx:if="{{error}}" class="error">{{error}}</view>
    </view>
</view>
