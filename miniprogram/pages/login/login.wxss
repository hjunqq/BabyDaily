.page {
    min-height: 100vh;
    padding: 36rpx 28rpx 48rpx;
    background:
        radial-gradient(circle at top left, rgba(243, 182, 194, 0.35), transparent 42%),
        linear-gradient(180deg, #fff7f8 0%, #fff3ef 100%);
    box-sizing: border-box;
}

.hero {
    padding: 40rpx 12rpx 28rpx;
}

.hero-badge {
    display: inline-flex;
    padding: 10rpx 22rpx;
    border-radius: 999rpx;
    background: rgba(255, 255, 255, 0.75);
    color: #b05c6f;
    font-size: 24rpx;
    font-weight: 600;
    margin-bottom: 22rpx;
}

.title {
    font-size: 52rpx;
    font-weight: 700;
    color: #4a342e;
}

.subtitle {
    margin-top: 16rpx;
    font-size: 26rpx;
    line-height: 1.7;
    color: #7a625a;
}

.card {
    padding: 30rpx 28rpx 34rpx;
    border-radius: 28rpx;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16rpx 36rpx rgba(126, 88, 79, 0.08);
}

.mode-switch {
    display: flex;
    gap: 16rpx;
    margin-bottom: 30rpx;
}

.mode-chip {
    flex: 1;
    text-align: center;
    padding: 18rpx 12rpx;
    border-radius: 999rpx;
    background: #f6ebe8;
    color: #7d655d;
    font-size: 26rpx;
    font-weight: 600;
}

.mode-chip.active {
    background: linear-gradient(135deg, #f3b6c2, #ef9fb0);
    color: #fff;
    box-shadow: 0 12rpx 26rpx rgba(239, 159, 176, 0.28);
}

.section-title {
    font-size: 34rpx;
    font-weight: 700;
    color: #4a342e;
}

.section-desc {
    margin-top: 12rpx;
    margin-bottom: 24rpx;
    font-size: 24rpx;
    line-height: 1.6;
    color: #8b7670;
}

.input {
    height: 88rpx;
    margin-bottom: 18rpx;
    padding: 0 24rpx;
    border-radius: 18rpx;
    border: 1rpx solid #ecd8d4;
    background: #fff;
    box-sizing: border-box;
    color: #4a342e;
    font-size: 28rpx;
}

.invite-input {
    font-size: 36rpx;
    text-align: center;
    letter-spacing: 10rpx;
    font-weight: 700;
}

.submit {
    margin-top: 14rpx;
    border-radius: 999rpx;
    background: linear-gradient(135deg, #f3b6c2, #ef9fb0);
    color: #fff;
}

.admin-submit {
    background: linear-gradient(135deg, #ffb27d, #ff8b6a);
}

.wechat-submit {
    margin-top: 0;
    margin-bottom: 8rpx;
    background: linear-gradient(135deg, #5fc28a, #2faa6b);
}

.divider {
    display: flex;
    align-items: center;
    gap: 16rpx;
    margin: 26rpx 0 22rpx;
    color: #b8a59f;
    font-size: 22rpx;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    height: 1rpx;
    background: #ecd8d4;
}

.error {
    margin-top: 24rpx;
    padding: 18rpx 22rpx;
    border-radius: 16rpx;
    background: #fff1f2;
    color: #b42318;
    font-size: 24rpx;
    line-height: 1.6;
}
