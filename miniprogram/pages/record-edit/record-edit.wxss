.container {
  min-height: 100vh;
  padding: 24rpx;
  background: #fdf6f4;
}

.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.state-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.state-text { font-size: 28rpx; color: #888; margin-bottom: 24rpx; }
.retry-btn { background: #F3B6C2; color: #fff; border-radius: 40rpx; font-size: 26rpx; }

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.field-label { font-size: 28rpx; color: #999; }
.field-value { font-size: 28rpx; color: #333; font-weight: 500; }

/* Feed */
.feed-type-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.feed-type-btn {
  flex: 1;
  padding: 18rpx;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #e5e5e5;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A342E;
}
.feed-type-btn.active {
  border-color: #F3B6C2;
  background: #F3B6C2;
  color: #fff;
}

.presets-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.sleep-grid { grid-template-columns: repeat(4, 1fr); }

.preset-btn {
  padding: 20rpx 0;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #e5e5e5;
  font-size: 24rpx;
  font-weight: 600;
  color: #4A342E;
}
.preset-btn.active {
  border-color: #F3B6C2;
  background: #F3B6C2;
  color: #fff;
}
.preset-btn.sleep-active {
  border-color: #B39DDB;
  background: #B39DDB;
  color: #fff;
}

.stepper-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}
.stepper-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #4A342E;
  background: #fff;
}
.stepper-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A342E;
  min-width: 160rpx;
  text-align: center;
}

/* Diaper */
.diaper-grid { display: flex; gap: 16rpx; }
.diaper-btn {
  flex: 1;
  padding: 28rpx 8rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 3rpx solid transparent;
  opacity: 0.6;
}
.diaper-btn.active { opacity: 1; border-width: 3rpx; }
.diaper-icon { font-size: 40rpx; }
.diaper-btn.pee { border-color: #64b5f6; background: #e3f2fd; color: #1565c0; }
.diaper-btn.pee.active { border-color: #1565c0; }
.diaper-btn.poo { border-color: #ffb74d; background: #fff3e0; color: #e65100; }
.diaper-btn.poo.active { border-color: #e65100; }
.diaper-btn.both { border-color: #ce93d8; background: #f3e5f5; color: #6a1b9a; }
.diaper-btn.both.active { border-color: #6a1b9a; }

/* Remark */
.remark-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  background: #f9f6f5;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* Submit */
.submit-section { margin-top: 8rpx; padding-bottom: 60rpx; }
.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #F3B6C2;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(243,182,194,0.4);
}
.submit-btn[disabled] { opacity: 0.5; }
