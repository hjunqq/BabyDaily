<view class="container">
  <!-- Type Tabs -->
  <view class="type-tabs">
    <block wx:for="{{types}}" wx:key="key">
      <view class="tab {{selectedType === item.key ? 'active' : ''}}" bindtap="selectType" data-type="{{item.key}}">
        <text class="tab-icon">{{item.icon}}</text>
        <text class="tab-label">{{item.label}}</text>
      </view>
    </block>
  </view>

  <!-- Feed Input -->
  <view wx:if="{{selectedType === 'FEED'}}" class="input-section">
    <view class="feed-type-row">
      <view class="feed-type-btn {{feedSubtype === 'BOTTLE' ? 'active' : ''}}" bindtap="setFeedSubtype" data-subtype="BOTTLE">🍼 瓶喂</view>
      <view class="feed-type-btn {{feedSubtype === 'BREAST' ? 'active' : ''}}" bindtap="setFeedSubtype" data-subtype="BREAST">🤱 亲喂</view>
      <view class="feed-type-btn {{feedSubtype === 'SOLID' ? 'active' : ''}}" bindtap="setFeedSubtype" data-subtype="SOLID">🥣 辅食</view>
    </view>

    <!-- Bottle / Solid: amount presets + stepper -->
    <block wx:if="{{feedSubtype === 'BOTTLE' || feedSubtype === 'SOLID'}}">
      <view class="presets-grid">
        <block wx:for="{{feedSubtype === 'SOLID' ? solidPresets : feedPresets}}" wx:key="*this">
          <view class="preset-btn {{amount === item ? 'active' : ''}}" bindtap="setAmount" data-amount="{{item}}">
            {{item}}ml
          </view>
        </block>
      </view>
      <view class="stepper-row">
        <view class="stepper-btn" bindtap="adjustAmount" data-delta="-10">−</view>
        <text class="stepper-value">{{amount}} ml</text>
        <view class="stepper-btn" bindtap="adjustAmount" data-delta="10">+</view>
      </view>
    </block>

    <!-- Breast: duration presets -->
    <view wx:if="{{feedSubtype === 'BREAST'}}" class="presets-grid">
      <block wx:for="{{breastPresets}}" wx:key="*this">
        <view class="preset-btn {{duration === item ? 'active' : ''}}" bindtap="setDuration" data-duration="{{item}}">
          {{item}}分钟
        </view>
      </block>
    </view>
  </view>

  <!-- Diaper Input -->
  <view wx:if="{{selectedType === 'DIAPER'}}" class="input-section">
    <text class="input-hint">点击即可保存</text>
    <view class="diaper-grid">
      <view class="diaper-btn pee" bindtap="quickSaveDiaper" data-type="PEE">
        <text class="diaper-icon">💧</text>
        <text>尿尿</text>
      </view>
      <view class="diaper-btn poo" bindtap="quickSaveDiaper" data-type="POO">
        <text class="diaper-icon">💩</text>
        <text>便便</text>
      </view>
      <view class="diaper-btn both" bindtap="quickSaveDiaper" data-type="BOTH">
        <text class="diaper-icon">💧💩</text>
        <text>都有</text>
      </view>
    </view>
  </view>

  <!-- Sleep Input -->
  <view wx:if="{{selectedType === 'SLEEP'}}" class="input-section">
    <view class="presets-grid sleep-grid">
      <block wx:for="{{sleepPresets}}" wx:key="*this">
        <view class="preset-btn {{sleepDuration === item ? 'active sleep-active' : ''}}" bindtap="setSleepDuration" data-duration="{{item}}">
          {{item >= 60 ? (item % 60 > 0 ? (item / 60 | 0) + 'h' + item % 60 + 'm' : (item / 60) + '小时') : item + '分钟'}}
        </view>
      </block>
    </view>
    <view class="sleep-display">
      <text class="sleep-icon">💤</text>
      <text class="sleep-value">{{sleepDuration}} 分钟</text>
    </view>
  </view>

  <!-- Bath Input -->
  <view wx:if="{{selectedType === 'BATH'}}" class="input-section">
    <view class="presets-grid">
      <block wx:for="{{bathPresets}}" wx:key="*this">
        <view class="preset-btn {{bathDuration === item ? 'active' : ''}}" bindtap="setBathDuration" data-duration="{{item}}">
          {{item}}分钟
        </view>
      </block>
    </view>
  </view>

  <!-- Topical (涂药膏) Input -->
  <view wx:if="{{selectedType === 'TOPICAL'}}" class="input-section">
    <text class="input-hint">药膏 / 外用药</text>
    <view class="presets-grid">
      <block wx:for="{{topicalPresets}}" wx:key="*this">
        <view class="preset-btn {{topicalProduct === item ? 'active' : ''}}" bindtap="setTopicalProduct" data-value="{{item}}">
          {{item}}
        </view>
      </block>
    </view>
    <input
      class="text-input"
      placeholder="或输入其他药膏名称"
      value="{{topicalProduct}}"
      bindinput="onTopicalProductInput"
      maxlength="40"
    />
    <text class="input-hint" style="margin-top: 20rpx;">部位（可选）</text>
    <input
      class="text-input"
      placeholder="如：颈部 / 屁屁 / 脸"
      value="{{topicalArea}}"
      bindinput="onTopicalAreaInput"
      maxlength="40"
    />
  </view>

  <!-- Solids (辅食) Input -->
  <view wx:if="{{selectedType === 'SOLIDS'}}" class="input-section">
    <text class="input-hint">辅食</text>
    <view class="presets-grid">
      <block wx:for="{{solidsFoodPresets}}" wx:key="*this">
        <view class="preset-btn {{solidsFood === item ? 'active' : ''}}" bindtap="setSolidsFood" data-value="{{item}}">
          {{item}}
        </view>
      </block>
    </view>
    <input
      class="text-input"
      placeholder="或输入其他辅食"
      value="{{solidsFood}}"
      bindinput="onSolidsFoodInput"
      maxlength="40"
    />
    <text class="input-hint" style="margin-top: 20rpx;">分量</text>
    <view class="stepper-row">
      <view class="stepper-btn" bindtap="adjustSolidsAmount" data-delta="-5">−</view>
      <input
        class="stepper-value-input"
        type="number"
        value="{{solidsAmount}}"
        bindinput="onSolidsAmountInput"
      />
      <view class="stepper-btn" bindtap="adjustSolidsAmount" data-delta="5">+</view>
    </view>
    <view class="presets-grid">
      <block wx:for="{{solidsUnits}}" wx:key="*this">
        <view class="preset-btn {{solidsUnit === item ? 'active' : ''}}" bindtap="setSolidsUnit" data-value="{{item}}">
          {{item}}
        </view>
      </block>
    </view>
  </view>

  <!-- Submit -->
  <view wx:if="{{selectedType !== 'DIAPER'}}" class="submit-section">
    <button class="submit-btn" bindtap="submit" disabled="{{submitting}}">
      {{submitting ? '保存中...' : '✓ 保存记录'}}
    </button>
  </view>
</view>
