.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFF7F9 100%);
}

/* Type Tabs */
.type-tabs {
  display: flex;
  background: rgba(0,0,0,0.04);
  padding: 6rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.tab {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 24rpx;
  color: #8b7670;
}

.tab.active {
  background: #fff;
  color: #4A342E;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 24rpx;
}

/* Input Section */
.input-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.input-hint {
  display: block;
  text-align: center;
  color: #8b7670;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

/* Feed Type Row */
.feed-type-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.feed-type-btn {
  flex: 1;
  padding: 18rpx;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #e5e5e5;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A342E;
}

.feed-type-btn.active {
  border-color: #F3B6C2;
  background: #F3B6C2;
  color: #fff;
}

/* Presets Grid */
.presets-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.presets-grid.sleep-grid {
  grid-template-columns: repeat(4, 1fr);
}

.preset-btn {
  padding: 24rpx 0;
  text-align: center;
  border-radius: 20rpx;
  border: 2rpx solid #e5e5e5;
  font-size: 26rpx;
  font-weight: 600;
  color: #4A342E;
}

.preset-btn.active {
  border-color: #F3B6C2;
  background: #F3B6C2;
  color: #fff;
}

.preset-btn.sleep-active {
  border-color: #B39DDB;
  background: #B39DDB;
}

/* Stepper */
.stepper-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.stepper-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #4A342E;
  background: #fff;
}

.stepper-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A342E;
  min-width: 160rpx;
  text-align: center;
}

/* Diaper Grid */
.diaper-grid {
  display: flex;
  gap: 16rpx;
}

.diaper-btn {
  flex: 1;
  padding: 32rpx 16rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.diaper-icon {
  font-size: 40rpx;
}

.diaper-btn.pee {
  border: 2rpx solid #64b5f6;
  background: #e3f2fd;
  color: #1565c0;
}

.diaper-btn.poo {
  border: 2rpx solid #ffb74d;
  background: #fff3e0;
  color: #e65100;
}

.diaper-btn.both {
  border: 2rpx solid #ce93d8;
  background: #f3e5f5;
  color: #6a1b9a;
}

/* Sleep Display */
.sleep-display {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.sleep-icon {
  font-size: 48rpx;
}

.sleep-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A342E;
}

/* Submit */
.submit-section {
  margin-top: 32rpx;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: #F3B6C2;
  color: #fff;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
}
