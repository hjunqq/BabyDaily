.page {
    min-height: 100vh;
    padding: 24rpx;
    background: linear-gradient(180deg, #fff5f7 0%, #fff9fb 100%);
    box-sizing: border-box;
}

.hero {
    margin-bottom: 20rpx;
    padding: 20rpx 8rpx;
}

.hero-title {
    font-size: 44rpx;
    font-weight: 700;
    color: #4a342e;
}

.hero-subtitle {
    margin-top: 8rpx;
    font-size: 24rpx;
    color: #8b7670;
}

.hero-actions {
    display: flex;
    gap: 16rpx;
    margin-bottom: 20rpx;
}

.card,
.state-card {
    margin-bottom: 20rpx;
    padding: 24rpx;
    border-radius: 24rpx;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 10rpx 26rpx rgba(92, 64, 53, 0.06);
}

.state-card {
    text-align: center;
}

.state-text,
.empty-text {
    font-size: 26rpx;
    color: #8b7670;
    line-height: 1.7;
}

.card-title {
    display: flex;
    align-items: center;
    gap: 10rpx;
    font-size: 30rpx;
    font-weight: 700;
    color: #4a342e;
}

.count {
    padding: 2rpx 14rpx;
    border-radius: 999rpx;
    background: #f9e3e9;
    color: #d46a87;
    font-size: 22rpx;
    font-weight: 600;
}

.role-switch {
    display: flex;
    gap: 14rpx;
    margin-top: 20rpx;
    margin-bottom: 20rpx;
    flex-wrap: wrap;
}

.role-chip {
    padding: 14rpx 24rpx;
    border-radius: 999rpx;
    background: #f6ebe8;
    color: #7d655d;
    font-size: 24rpx;
    font-weight: 600;
}

.role-chip.active {
    background: linear-gradient(135deg, #f3b6c2, #ef9fb0);
    color: #fff;
}

.primary-btn {
    border-radius: 999rpx;
    background: linear-gradient(135deg, #f3b6c2, #ef9fb0);
    color: #fff;
}

.secondary-btn {
    margin-top: 18rpx;
    border-radius: 999rpx;
    background: #f7efeb;
    color: #5c4035;
}

.action-btn {
    flex: 1;
    margin-top: 0;
}

.invite-box {
    margin-top: 22rpx;
    padding: 22rpx;
    border-radius: 20rpx;
    background: #fff6f8;
    border: 1rpx solid #f2d7df;
}

.invite-code {
    font-size: 42rpx;
    letter-spacing: 10rpx;
    font-weight: 700;
    color: #c45776;
}

.invite-meta {
    margin-top: 10rpx;
    font-size: 23rpx;
    color: #8b7670;
}

.member-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16rpx;
    padding: 22rpx 0;
    border-bottom: 1rpx solid #f3ece8;
}

.member-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
}

.member-main {
    flex: 1;
    min-width: 0;
}

.member-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #4a342e;
    word-break: break-all;
}

.member-role {
    margin-top: 8rpx;
    font-size: 22rpx;
    color: #8b7670;
}

.member-status {
    font-size: 22rpx;
    color: #d46a87;
    white-space: nowrap;
}

.member-actions {
    display: flex;
    gap: 10rpx;
}

.mini-btn {
    margin: 0;
    padding: 0 24rpx;
    border-radius: 999rpx;
    line-height: 1.9;
}

.approve-btn {
    background: #eaf8f0;
    color: #1f8f52;
}

.reject-btn {
    background: #fff1f2;
    color: #b42318;
}
